            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Chalet 1\",\n  \"description\": \"Chalet ristrutturato\",\n  \"maxCapacity\": 5,\n  \"pricePerNight\": 95.00,\n  \"type\": \"CHALET\",\n  \"rooms\": 3,\n  \"beds\": 5,\n  \"hasBathroom\": true,\n  \"hasKitchen\": true,\n  \"hasAc\": true\n}" }
          }
        },
        {
          "name": "Elimina alloggio",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/accommodations/21", "host": ["{{baseUrl}}"], "path": ["api","accommodations","21"] }
          }
        }
      ]
