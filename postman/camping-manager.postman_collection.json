            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Chalet 11\",\n  \"description\": \"Chalet in legno\",\n  \"maxCapacity\": 4,\n  \"pricePerNight\": 90.00,\n  \"type\": \"CHALET\",\n  \"rooms\": 2,\n  \"beds\": 4,\n  \"hasBathroom\": true,\n  \"hasKitchen\": true,\n  \"hasAc\": true\n}" }
          }
