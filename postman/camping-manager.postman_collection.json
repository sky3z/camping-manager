{
  "info": {
    "name": "Camping Manager API",
    "description": "Collection completa del backend Camping Manager (EPICODE - Backend Programming). Esegui prima 'Auth > Login': il token viene salvato in {{token}} e usato dalle richieste protette.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token salvato');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@camping.it\",\n  \"password\": \"Admin123!\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Profilo",
      "item": [
        {
          "name": "Profilo corrente",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api","users","me"] }
          }
        },
        {
          "name": "Aggiorna immagine profilo",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/users/me/avatar", "host": ["{{baseUrl}}"], "path": ["api","users","me","avatar"] },
            "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": [] } ] }
          }
        },
        {
          "name": "Cambia password",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/users/me/password", "host": ["{{baseUrl}}"], "path": ["api","users","me","password"] },
            "body": { "mode": "raw", "raw": "{\n  \"oldPassword\": \"Admin123!\",\n  \"newPassword\": \"NuovaPassword123!\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin - Utenti",
      "item": [
        {
          "name": "Lista utenti",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/admin/users?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api","admin","users"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" }, { "key": "role", "value": "STAFF", "disabled": true } ] }
          }
        },
        {
          "name": "Dettaglio utente",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/admin/users/1", "host": ["{{baseUrl}}"], "path": ["api","admin","users","1"] }
          }
        },
        {
          "name": "Crea staff",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/admin/staff", "host": ["{{baseUrl}}"], "path": ["api","admin","staff"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"reception@camping.it\",\n  \"password\": \"Password123!\",\n  \"name\": \"Luca\",\n  \"surname\": \"Verdi\",\n  \"department\": \"RECEPTION\"\n}" }
          }
        },
        {
          "name": "Elimina utente",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/admin/users/2", "host": ["{{baseUrl}}"], "path": ["api","admin","users","2"] }
          }
        }
      ]
    },
    {
      "name": "Alloggi",
